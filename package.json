{
  "name": "alby",
  "productName": "Alby",
  "version": "0.8.4",
  "description": "The desktop control room for AI coding agents — run Claude Code, Gemini and Codex across every server you own.",
  "author": {
    "name": "Alberto Pisaroni",
    "email": "a.pisaroni@truesolutions.io"
  },
  "license": "BUSL-1.1",
  "homepage": "https://alby.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alby-sh/alby.git"
  },
  "bugs": {
    "url": "https://github.com/alby-sh/alby/issues"
  },
  "keywords": [
    "electron",
    "claude-code",
    "gemini",
    "codex",
    "ai-agents",
    "ssh",
    "tmux",
    "terminal",
    "devtool",
    "macos"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "ALBY_ENVIRONMENT=Local electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --mac --config electron-builder.yml --publish never",
    "package:universal": "electron-vite build && electron-builder --mac --universal --config electron-builder.yml --publish never",
    "postpackage": "electron-builder install-app-deps",
    "postpackage:universal": "electron-builder install-app-deps",
    "typecheck:main": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer"
  },
  "dependencies": {
    "@alby-sh/report": "^0.1.0",
    "@carbon/icons-react": "^11.78.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.62.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "jdenticon": "^3.3.0",
    "lucide-react": "^1.8.0",
    "node-pty": "^1.1.0",
    "pusher-js": "^8.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ssh-config": "^5.0.0",
    "ssh2": "^1.16.0",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
